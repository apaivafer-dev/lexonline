generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model banners {
  id                 String  @id
  user_id            String
  company_id         String
  company_name       String  @default("")
  review_link        String? @default("")
  banner_title       String? @default("")
  banner_description String? @default("")
  qr_instruction     String? @default("")
  instructions       String? @default("")
  banner_color       String? @default("#e74c3c")
  font_color         String? @default("#ffffff")
  frame_type         String? @default("google")
  created_at         String  @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at         String  @default(dbgenerated("CURRENT_TIMESTAMP"))
  users              users   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_banners_user_id")
}

model cards {
  id         String  @id
  user_id    String
  company_id String
  card_name  String  @default("Meu Cartão")
  config     Json    @default("{}")
  created_at String  @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at String  @default(dbgenerated("CURRENT_TIMESTAMP"))
  deleted_at String?
  users      users   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_cards_user_id")
}

model company_profiles {
  id           String  @id
  user_id      String  @unique
  name         String
  phone        String?
  email        String?
  website      String?
  cep          String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  created_at   String  @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at   String  @default(dbgenerated("CURRENT_TIMESTAMP"))
  users        users   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model crm_companies {
  id            String   @id
  user_id       String
  company_id    String
  name          String
  trade_name    String
  emails        Json     @default("[]")
  phones        Json     @default("[]")
  types         String[] @default([])
  custom_values Json?    @default("{}")
  tags          String[] @default([])
  created_at    String   @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at    String   @default(dbgenerated("CURRENT_TIMESTAMP"))
  users         users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_crm_companies_user_id")
}

model crm_contacts {
  id             String   @id
  user_id        String
  company_id     String
  first_name     String
  last_name      String   @default("")
  cpf            String?
  emails         Json     @default("[]")
  phones         Json     @default("[]")
  type           String   @default("Lead")
  crm_company_id String?
  custom_values  Json?    @default("{}")
  tags          String[] @default([])
  created_at     String   @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at     String   @default(dbgenerated("CURRENT_TIMESTAMP"))
  users          users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([company_id], map: "idx_crm_contacts_company_id")
  @@index([crm_company_id], map: "idx_crm_contacts_crm_company_id")
  @@index([user_id], map: "idx_crm_contacts_user_id")
}

model crm_tags {
  id          String @id
  user_id     String
  company_id  String
  name        String
  color       String @default("#3B82F6")
  entity_type String
  created_at  String @default(dbgenerated("CURRENT_TIMESTAMP"))
  users       users  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([entity_type], map: "idx_crm_tags_entity_type")
  @@index([user_id], map: "idx_crm_tags_user_id")
}

model custom_fields {
  id            String   @id
  user_id       String
  company_id    String
  key           String
  label         String
  type          String   @default("text")
  entity_type   String
  field_group   String?  @default("Geral")
  required      Boolean  @default(false)
  placeholder   String?
  default_value String?
  options       Json?    @default("[]")
  button_config Json?
  pipeline_ids  String[] @default([])
  created_at    String   @default(dbgenerated("CURRENT_TIMESTAMP"))
  users         users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([entity_type], map: "idx_custom_fields_entity_type")
  @@index([user_id], map: "idx_custom_fields_user_id")
}

model leads {
  id              String          @id
  user_id         String
  pipeline_id     String
  stage_id        String
  name            String
  email           String?
  phone           String?
  estimated_value Float?          @default(0) @db.Real
  notes           String?
  created_at      String          @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at      String          @default(dbgenerated("CURRENT_TIMESTAMP"))
  company_id      String?
  custom_values   Json?           @default("{}")
  tags            String[]        @default([])
  pipelines       pipelines       @relation(fields: [pipeline_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pipeline_stages pipeline_stages @relation(fields: [stage_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([company_id], map: "idx_leads_company_id")
  @@index([created_at(sort: Desc)], map: "idx_leads_created_at")
  @@index([pipeline_id], map: "idx_leads_pipeline_id")
  @@index([stage_id], map: "idx_leads_stage_id")
  @@index([user_id], map: "idx_leads_user_id")
  @@index([user_id, pipeline_id], map: "idx_leads_user_pipeline")
}

model pipeline_stages {
  id          String    @id
  pipeline_id String
  name        String
  stage_order Int       @default(0)
  type        String    @default("active")
  color       String    @default("blue")
  created_at  String    @default(dbgenerated("CURRENT_TIMESTAMP"))
  leads       leads[]
  pipelines   pipelines @relation(fields: [pipeline_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([pipeline_id], map: "idx_pipeline_stages_pipeline_id")
}

model pipelines {
  id              String            @id
  user_id         String
  name            String
  is_system       Int               @default(0)
  show_value      Int               @default(1)
  show_total      Int               @default(1)
  sort_order      Int               @default(0)
  created_at      String            @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at      String            @default(dbgenerated("CURRENT_TIMESTAMP"))
  company_id      String?
  leads           leads[]
  pipeline_stages pipeline_stages[]
  users           users             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([company_id], map: "idx_pipelines_company_id")
  @@index([user_id], map: "idx_pipelines_user_id")
}

model plan_features {
  id          String  @id
  plan_id     String
  feature_key String
  enabled     Boolean @default(true)
  label       String
  description String?
  sort_order  Int     @default(0)
  plans       plans   @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([plan_id, feature_key])
}

model plan_limits {
  id          String  @id
  plan_id     String
  limit_key   String
  limit_value Int     @default(-1)
  label       String
  description String?
  sort_order  Int     @default(0)
  plans       plans   @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([plan_id, limit_key])
}

model plans {
  id                      String          @id
  slug                    String          @unique
  name                    String
  description             String?
  sort_order              Int             @default(0)
  is_active               Boolean         @default(true)
  price_monthly           Decimal         @default(0) @db.Decimal(10, 2)
  price_yearly            Decimal         @default(0) @db.Decimal(10, 2)
  stripe_price_id_monthly String?
  stripe_price_id_yearly  String?
  created_at              String          @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at              String          @default(dbgenerated("CURRENT_TIMESTAMP"))
  plan_features           plan_features[]
  plan_limits             plan_limits[]
  users                   users[]
}

model published_calculators {
  id                String   @id
  user_id           String   @unique
  slug              String   @unique
  company_name      String?  @default("")
  primary_color     String?  @default("#2563eb")
  whatsapp_number   String?  @default("")
  whatsapp_message  String?  @default("")
  show_lead_form    Boolean? @default(true)
  custom_css        String?  @default("")
  is_active         Boolean? @default(true)
  created_at        String   @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at        String   @default(dbgenerated("CURRENT_TIMESTAMP"))
  header_bg_color   String?  @default("#0f172a")
  header_font_color String?  @default("#ffffff")
  config            Json?    @default("{}")
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([slug], map: "idx_published_calculators_slug")
}

model users {
  id                    String                 @id
  name                  String
  email                 String                 @unique
  password_hash         String
  phone                 String?
  firm_name             String?
  plan                  String                 @default("Pro")
  subscription_status   String                 @default("Active")
  is_admin              Int                    @default(0)
  leads_count           Int                    @default(0)
  banners_count         Int                    @default(0)
  cards_count           Int                    @default(0)
  trial_ends_at         String?
  paid_start_date       String?
  courtesy_start_date   String?
  created_at            String                 @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at            String                 @default(dbgenerated("CURRENT_TIMESTAMP"))
  company_id            String?
  role                  String                 @default("User")
  slug                  String?                @unique
  email_confirmed       Boolean?               @default(true)
  confirmation_token    String?
  reset_token           String?
  token_expires_at      String?
  last_login_at         String?
  theme                 String                 @default("light")
  plan_id               String?
  banners               banners[]
  cards                 cards[]
  company_profiles      company_profiles?
  crm_companies         crm_companies[]
  crm_contacts          crm_contacts[]
  crm_tags              crm_tags[]
  custom_fields         custom_fields[]
  leads                 leads[]
  pipelines             pipelines[]
  published_calculators published_calculators?
  plans                 plans?                 @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_plan")

  @@index([company_id], map: "idx_users_company_id")
  @@index([email], map: "idx_users_email")
}

// ── Builder Backend Models ──

model pages {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  team_id       String?   @db.Uuid
  title         String    @db.VarChar(255)
  slug          String    @db.VarChar(255)
  description   String?
  status        String    @default("draft") @db.VarChar(20)
  schema        Json      @default("[]")
  metadata      Json?     @default("{}")
  published_url String?   @db.VarChar(500)
  published_at  DateTime? @db.Timestamp()
  domain_id     String?   @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamp()
  updated_at    DateTime  @updatedAt @db.Timestamp()

  page_domains  page_domains[]
  page_leads    page_leads[]
  page_assets   page_assets[]
  page_views    page_views[]
  ab_tests      ab_tests[]
  page_versions page_versions[]

  @@unique([user_id, slug])
  @@index([user_id])
  @@index([status])
  @@index([slug])
}

model page_templates {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String   @db.VarChar(255)
  slug          String   @unique @db.VarChar(255)
  description   String?
  category      String   @db.VarChar(50)
  thumbnail_url String?  @db.VarChar(500)
  schema        Json
  is_premium    Boolean  @default(false)
  preview_url   String?  @db.VarChar(500)
  created_at    DateTime @default(now()) @db.Timestamp()
  updated_at    DateTime @updatedAt @db.Timestamp()

  @@index([category])
  @@index([is_premium])
}

model page_versions {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  page_id        String   @db.Uuid
  version_number Int
  schema         Json
  metadata       Json?    @default("{}")
  created_at     DateTime @default(now()) @db.Timestamp()
  created_by     String?  @db.Uuid

  page pages @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@unique([page_id, version_number])
  @@index([page_id])
  @@index([created_at])
}

model page_leads {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  page_id    String   @db.Uuid
  name       String?  @db.VarChar(255)
  email      String   @db.VarChar(255)
  phone      String?  @db.VarChar(20)
  message    String?
  form_id    String?  @db.VarChar(100)
  metadata   Json?    @default("{}")
  created_at DateTime @default(now()) @db.Timestamp()
  updated_at DateTime @updatedAt @db.Timestamp()
  source_url String?  @db.VarChar(500)
  area       String?  @db.VarChar(100)
  status     String   @default("novo") @db.VarChar(20) // novo | contatado | convertido | perdido
  source     String?  @db.VarChar(100)

  page pages @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@index([page_id])
  @@index([email])
  @@index([created_at])
  @@index([status])
}

model page_assets {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  page_id       String   @db.Uuid
  user_id       String   @db.Uuid
  filename      String   @db.VarChar(255)
  file_type     String?  @db.VarChar(50)
  file_size     Int?
  firebase_url  String   @db.VarChar(500)
  firebase_path String   @db.VarChar(500)
  width         Int?
  height        Int?
  created_at    DateTime @default(now()) @db.Timestamp()

  page pages @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@index([page_id])
  @@index([user_id])
}

model page_domains {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  page_id       String?   @db.Uuid
  domain        String    @unique @db.VarChar(255)
  status        String    @default("pending") @db.VarChar(20)
  error_message String?
  is_verified   Boolean   @default(false)
  verified_at   DateTime? @db.Timestamp()
  dns_records   Json?
  created_at    DateTime  @default(now()) @db.Timestamp()
  updated_at    DateTime  @updatedAt @db.Timestamp()

  page pages? @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([domain])
  @@index([page_id])
}

model page_views {
  id           BigInt   @id @default(autoincrement())
  page_id      String   @db.Uuid
  session_id   String?  @db.VarChar(100)
  user_agent   String?
  ip_address   String?
  referrer     String?  @db.VarChar(500)
  utm_source   String?  @db.VarChar(100)
  utm_medium   String?  @db.VarChar(100)
  utm_campaign String?  @db.VarChar(100)
  scroll_depth Int?
  time_on_page Int?
  device       String?  @db.VarChar(20)
  created_at   DateTime @default(now()) @db.Timestamp()

  page pages @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@index([page_id])
  @@index([session_id])
  @@index([created_at])
}

model ab_tests {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  page_id          String    @db.Uuid
  element_id       String    @db.VarChar(100)
  name             String    @db.VarChar(255)
  status           String    @default("active") @db.VarChar(20) // active | paused | concluded
  variant_a_schema Json
  variant_b_schema Json
  split_a          Int       @default(50) // % de tráfego para A
  split_b          Int       @default(50) // % de tráfego para B
  traffic_split    Int       @default(50) // legado — mantido para compatibilidade
  metric_type      String?   @db.VarChar(50)
  winner           String?   @db.VarChar(1)  // 'A' | 'B'
  created_at       DateTime  @default(now()) @db.Timestamp()
  started_at       DateTime? @db.Timestamp()
  ends_at          DateTime? @db.Timestamp()  // data planejada de encerramento
  ended_at         DateTime? @db.Timestamp()  // data real de encerramento
  concluded_at     DateTime? @db.Timestamp()

  page     pages      @relation(fields: [page_id], references: [id], onDelete: Cascade)
  ab_events ab_events[]

  @@index([page_id])
  @@index([status])
}

model ab_events {
  id         BigInt   @id @default(autoincrement())
  test_id    String   @db.Uuid
  event_type String   @db.VarChar(20)  // 'impression' | 'conversion'
  variant    String   @db.VarChar(1)   // 'A' | 'B'
  session_id String?  @db.VarChar(255)
  device     String?  @db.VarChar(50)
  source     String?  @db.VarChar(500)
  value      Decimal? @db.Decimal(10, 2)
  created_at DateTime @default(now()) @db.Timestamp()

  ab_test ab_tests @relation(fields: [test_id], references: [id], onDelete: Cascade)

  @@index([test_id, created_at])
  @@index([test_id, event_type, variant])
}

model ai_usage_logs {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @db.Uuid
  page_id         String?  @db.Uuid
  request_type    String?  @db.VarChar(50)
  tokens_used     Int?
  response_length Int?
  created_at      DateTime @default(now()) @db.Timestamp()

  @@index([user_id])
  @@index([created_at])
}

model collections {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @db.VarChar(255)
  description String?
  fields      Json     @default("[]") // Field[]
  created_at  DateTime @default(now()) @db.Timestamp()
  updated_at  DateTime @updatedAt @db.Timestamp()

  items            collection_items[]
  template_bindings template_bindings[]

  @@unique([user_id, slug])
  @@index([user_id])
}

model collection_items {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collection_id String   @db.Uuid
  data          Json     @default("{}") // {fieldSlug: value, ...}
  order_index   Int      @default(0)
  published     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamp()
  updated_at    DateTime @updatedAt @db.Timestamp()

  collection collections @relation(fields: [collection_id], references: [id], onDelete: Cascade)

  @@index([collection_id])
  @@index([order_index])
}

model template_bindings {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  page_id             String   @db.Uuid
  collection_id       String   @db.Uuid
  template_element_id String   @db.VarChar(100)
  url_pattern         String   @db.VarChar(500)
  output_folder       String?  @db.VarChar(500)
  created_at          DateTime @default(now()) @db.Timestamp()

  collection collections @relation(fields: [collection_id], references: [id], onDelete: Cascade)

  @@index([page_id])
  @@index([collection_id])
}
